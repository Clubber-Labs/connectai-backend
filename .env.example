# ══════════════════════════════════════════════════════════════════════════════
# ConnectAI Backend — variáveis de ambiente
# Copie para .env e preencha. Os valores abaixo são os defaults de
# desenvolvimento; chaves vazias são opcionais salvo indicação em contrário.
# ══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
# Ambiente de execução: development | test | production.
NODE_ENV=development
# Porta HTTP do servidor.
PORT=3333
# URL pública da API (links absolutos, ex.: uploads locais).
PUBLIC_URL=http://localhost:3333
# Nível dos logs: trace | debug | info | warn | error | fatal | silent.
LOG_LEVEL=info

# ── Banco & infra ─────────────────────────────────────────────────────────────
# PostgreSQL/PostGIS via Prisma (testes usam conectai_test via .env.test).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/conectai_dev"
# Segredo de assinatura dos JWTs de sessão. NUNCA versione um valor real:
# qualquer um com este segredo forja token de qualquer usuário. Gere o seu com:
#   openssl rand -hex 32
JWT_SECRET="GERE_UM_SECRET_FORTE_COM_openssl_rand_hex_32"
# Validade do access token (formato do `ms`: 15m, 1h, 7d). Default 15m — curto de
# propósito; o refresh token renova a sessão de forma transparente.
JWT_EXPIRES_IN=15m
# Validade do refresh token de sessão longa (rotativo, revogável). Default 90d.
REFRESH_TOKEN_EXPIRES_IN=90d
# CORS: CSV de origens permitidas (ex.: https://app.connectai.app,https://admin.connectai.app).
# OBRIGATÓRIO em produção. Vazio (dev/test) reflete a Origin da requisição.
CORS_ALLOWED_ORIGINS=
# Redis — rate-limit distribuído e fila de notificações (BullMQ).
# Obrigatório em produção quando NOTIFICATIONS_ENABLED=true.
REDIS_URL="redis://localhost:6379"

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Master switch do @fastify/rate-limit. false desliga TODO o throttling — útil
# pra teste de carga medir throughput sem 429 poluindo as métricas.
RATE_LIMIT_ENABLED=true
# Multiplicador aplicado ao limite de TODAS as rotas (1 = limites de projeto).
# Ex.: 1000 deixa os tetos efetivamente "ilimitados" pra medir vazão pura.
RATE_LIMIT_MAX_FACTOR=1
# Janela global dos limites (formato @fastify/rate-limit, ex.: '1 minute', '30 seconds').
RATE_LIMIT_WINDOW="1 minute"

# ── Storage & mídia ───────────────────────────────────────────────────────────
# Driver de arquivos: cloudinary (default) | local (dev sem conta).
STORAGE_DRIVER=cloudinary
# Diretório dos uploads quando STORAGE_DRIVER=local (default: ./uploads).
# Deixe COMENTADO se não for usar: vazio não é nulo (path.resolve('') = cwd).
# UPLOADS_DIR=
# Cloudinary — pares DEV/PROD; o backend escolhe pelo NODE_ENV.
CLOUDINARY_CLOUD_NAME_DEV=
CLOUDINARY_API_KEY_DEV=
CLOUDINARY_API_SECRET_DEV=
CLOUDINARY_CLOUD_NAME_PROD=
CLOUDINARY_API_KEY_PROD=
CLOUDINARY_API_SECRET_PROD=
# Opcional (recurso pago): auth key p/ URLs assinadas com expiração.
CLOUDINARY_AUTH_TOKEN_KEY=
# Cota de mídia de chat por usuário, em bytes (default 1 GB).
CHAT_USER_STORAGE_QUOTA_BYTES=1073741824

# ── E-mail & recuperação de senha ─────────────────────────────────────────────
# Driver de envio: log (dev — imprime o OTP no terminal) | resend (envio real).
# Em produção `log` é rejeitado no boot — use resend + RESEND_API_KEY.
EMAIL_DRIVER=log
# Chave da API do Resend (obrigatória quando EMAIL_DRIVER=resend).
RESEND_API_KEY=
# Remetente dos e-mails transacionais.
EMAIL_FROM="ConnectAI <no-reply@connectai.app>"
# Validade (min) do código OTP de recuperação.
PASSWORD_RESET_CODE_TTL_MINUTES=15
# Máximo de tentativas por código (anti brute-force).
PASSWORD_RESET_MAX_ATTEMPTS=5
# Cooldown (s) entre solicitações de código por conta (anti email bombing).
PASSWORD_RESET_REQUEST_COOLDOWN_SECONDS=60
# Expurgo (LGPD) dos códigos usados/expirados: tick (ms) e liga/desliga.
PASSWORD_RESET_CLEANUP_INTERVAL_MS=3600000
PASSWORD_RESET_CLEANUP_ENABLED=true

# ── Login social & APIs externas ──────────────────────────────────────────────
# Google OAuth — Client ID do Google Cloud Console (mesmo client_id do app).
GOOGLE_CLIENT_ID=
# Facebook OAuth — app de developers.facebook.com (o secret valida o token).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Google Places API (New) — estabelecimentos pras sugestões de spot.
# Sem ela, POST /spots/suggestions responde 503.
GOOGLE_PLACES_API_KEY=
# Anthropic (Claude) — copy e ranking das sugestões de spot. Sem ela, cai num
# template determinístico (degradação graciosa). Chave de console.anthropic.com.
ANTHROPIC_API_KEY=

# ── Stripe & billing ──────────────────────────────────────────────────────────
# Test mode em dev, live em prod. Setup:
#   1. STRIPE_SECRET_KEY em https://dashboard.stripe.com/test/apikeys
#   2. Crie Product+Price recorrente mensal → STRIPE_PREMIUM_PRICE_ID
#   3. Webhooks em dev: `stripe listen --forward-to localhost:3333/webhooks/stripe`
#      e cole aqui o whsec_ exibido.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_...
# URLs de retorno do checkout web.
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/billing/canceled
# CSV de hosts aceitos no override de success/cancel via body (anti open-redirect).
STRIPE_CHECKOUT_ALLOWED_REDIRECT_HOSTS=localhost:3000,localhost:3333
# Retenção (LGPD) dos webhook_events — o payload guarda o evento Stripe inteiro.
BILLING_WEBHOOK_RETENTION_DAYS=90
BILLING_WEBHOOK_RETENTION_CLEANUP_INTERVAL_MS=3600000
BILLING_WEBHOOK_RETENTION_CLEANUP_ENABLED=true
# Re-sync de assinaturas com período vencido além do grace — rede de segurança
# pra webhook perdido (sem isso, cancelamento perdido = premium pra sempre).
BILLING_SYNC_INTERVAL_MS=3600000
BILLING_SYNC_GRACE_MS=21600000
BILLING_SYNC_ENABLED=true

# ── Notificações (push + in-app) ──────────────────────────────────────────────
# Master switch — OFF por padrão. Em produção exige REDIS_URL (fila BullMQ).
NOTIFICATIONS_ENABLED=false
# Token do projeto Expo (só com "Enhanced Security for Push" ligado no EAS).
EXPO_ACCESS_TOKEN=
# Retenção (LGPD) das in-app: dias até o expurgo, tick (ms) e liga/desliga.
NOTIFY_RETENTION_DAYS=180
NOTIFY_RETENTION_CLEANUP_INTERVAL_MS=3600000
NOTIFY_RETENTION_CLEANUP_ENABLED=true
# Push de proximidade: teto do raio por usuário (km).
NOTIFY_MAX_RADIUS_KM=50
# Frescor da localização (dias) — mais velha não recebe push e é expurgada.
NOTIFY_LOCATION_TTL_DAYS=90
NOTIFY_LOCATION_CLEANUP_INTERVAL_MS=3600000
NOTIFY_LOCATION_CLEANUP_ENABLED=true
# Fan-out: tamanho da página da query de destinatários.
NOTIFY_FANOUT_BATCH_SIZE=500
# Receipts do Expo: idade mínima do ticket (ms, ~15min), tick e liga/desliga.
NOTIFY_RECEIPTS_DELAY_MS=900000
NOTIFY_RECEIPTS_INTERVAL_MS=300000
NOTIFY_RECEIPTS_ENABLED=true

# ── Reconcilers de domínio ────────────────────────────────────────────────────
# Nenhum reconciler roda em NODE_ENV=test.
# Destaques: expira featured events vencidos — tick (ms) e liga/desliga.
FEATURED_RECONCILE_INTERVAL_MS=300000
FEATURED_RECONCILE_ENABLED=true
# Exclusão de conta (soft-delete): carência (dias) até a anonimização definitiva.
ACCOUNT_DELETION_GRACE_DAYS=30
ACCOUNT_DELETION_INTERVAL_MS=3600000
ACCOUNT_DELETION_ENABLED=true
# Moderação: expira suspensões temporárias vencidas (ban é permanente).
SUSPENSION_RECONCILE_INTERVAL_MS=3600000
SUSPENSION_RECONCILE_ENABLED=true
# Spots: lembrete de renovação (LEAD = antecedência em ms) + limpeza no fim.
SPOT_LIFECYCLE_INTERVAL_MS=3600000
SPOT_RENEWAL_LEAD_MS=3600000
SPOT_LIFECYCLE_ENABLED=true

# ── Observabilidade ───────────────────────────────────────────────────────────
# Todas opcionais — OFF quando não configuradas.
# Sentry — rastreio de erros 500.
SENTRY_DSN=
# OpenTelemetry — só ativa com OTEL_ENABLED=true E endpoint OTLP definido.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=connectai-backend
# Loki — logs centralizados correlacionados por trace_id. Sem URL: só stdout.
LOKI_URL=http://localhost:3100
# Prometheus em /metrics (ligado por padrão — o scraper depende dele).
METRICS_ENABLED=true
# Se definido, /metrics exige `Authorization: Bearer <token>`. Deixe COMENTADO
# se não for usar: o schema rejeita string vazia (min 1) e o boot falharia.
# METRICS_TOKEN=
