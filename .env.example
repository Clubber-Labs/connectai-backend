DATABASE_URL="postgresql://postgres:postgres@localhost:5432/conectai_dev"
JWT_SECRET="conectai_secret_dev"
PORT=3333
NODE_ENV=development

# Redis — opcional. Sem ele, o cache fica desabilitado e o rate limit opera em memória local.
REDIS_URL="redis://localhost:6379"

# Storage driver: "cloudinary" (default) ou "local"
STORAGE_DRIVER=cloudinary

# Public URL — usado pelo LocalStorageService para montar URLs servidas via /uploads
PUBLIC_URL=http://localhost:3333

# Diretório de uploads (usado quando STORAGE_DRIVER=local).
# Default: ./uploads relativo ao process.cwd().
UPLOADS_DIR=

# Cloudinary — configure DEV e PROD separadamente.
# O backend escolhe o par baseado em NODE_ENV (production = PROD, qualquer outro = DEV).
CLOUDINARY_CLOUD_NAME_DEV=
CLOUDINARY_API_KEY_DEV=
CLOUDINARY_API_SECRET_DEV=

CLOUDINARY_CLOUD_NAME_PROD=
CLOUDINARY_API_KEY_PROD=
CLOUDINARY_API_SECRET_PROD=
