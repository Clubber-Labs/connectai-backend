PUBLIC_URL=http://localhost:3333
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/conectai_dev"
JWT_SECRET="conectai_secret_dev"
PORT=3333
NODE_ENV=development
REDIS_URL="redis://localhost:6379"
STORAGE_DRIVER=cloudinary

# Diretório de uploads (usado quando STORAGE_DRIVER=local).
# Default: ./uploads relativo ao process.cwd().
UPLOADS_DIR=

# Cloudinary — configure DEV e PROD separadamente.
# O backend escolhe o par baseado em NODE_ENV (production = PROD, qualquer outro = DEV).
CLOUDINARY_CLOUD_NAME_DEV=
CLOUDINARY_API_KEY_DEV=
CLOUDINARY_API_SECRET_DEV=
CLOUDINARY_CLOUD_NAME_PROD=
CLOUDINARY_API_KEY_PROD=
CLOUDINARY_API_SECRET_PROD=
CLOUDINARY_AUTH_TOKEN_KEY=
CHAT_USER_STORAGE_QUOTA_BYTES=1073741824

# ──────────────────────────────────────────────────────────────────────────────
# Exclusão de conta (soft-delete estilo Instagram).
# Carência (dias) entre o pedido de exclusão e a anonimização definitiva.
ACCOUNT_DELETION_GRACE_DAYS=30
# Intervalo (ms) do reconciler que anonimiza contas com carência vencida. Default 1h.
ACCOUNT_DELETION_INTERVAL_MS=3600000
# Liga/desliga o reconciler (não roda em NODE_ENV=test).
ACCOUNT_DELETION_ENABLED=true

# OAuth social — Google
# Client ID do OAuth Client criado no Google Cloud Console.
# Deve coincidir com o client_id usado pelo app mobile (audience do ID token).
GOOGLE_CLIENT_ID=

# OAuth social — Facebook
# App ID e App Secret do app criado em developers.facebook.com.
# O App Secret é usado para montar o app access token (debug_token).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# Observabilidade — TODAS opcionais e OFF por padrão quando não configuradas.

SENTRY_DSN=

# OpenTelemetry tracing. Só ativa se OTEL_ENABLED=true E o endpoint OTLP definido.
# Aponta para o Tempo da stack local (OTLP HTTP em 4318).
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=connectai-backend

# Loki (logs centralizados, correlacionados ao trace pelo trace_id). Sem a URL,
# os logs ficam apenas no stdout. Aponta para o Loki da stack local.
LOKI_URL=http://localhost:3100

# Métricas Prometheus em /metrics. Ligado por padrão (o scraper precisa delas).
# METRICS_ENABLED=false desliga a coleta e o endpoint por completo.
METRICS_ENABLED=true
# Se definido, /metrics exige `Authorization: Bearer <token>`. Recomendado quando
# a API fica exposta à internet (o scraper precisa enviar o mesmo token).
METRICS_TOKEN=

