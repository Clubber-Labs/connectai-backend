// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  // `native` cobre o dev local; `debian-openssl-3.0.x` é o runtime da imagem
  // Docker (node:24-slim / bookworm) usada nos testes de carga.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

// Ciclo de vida da conta (soft-delete estilo Instagram):
// ACTIVE -> DEACTIVATED (desativar) / PENDING_DELETION (excluir, com carência)
// -> ACTIVE (reativar no login) ou ANONYMIZED (job após a carência, terminal).
enum AccountStatus {
  ACTIVE
  DEACTIVATED
  PENDING_DELETION
  ANONYMIZED
}

model User {
  id             String   @id @default(uuid())
  name           String
  lastname       String
  username       String   @unique
  email          String   @unique
  password       String?
  phone          String?  @unique
  bio            String?
  avatarUrl      String?
  avatarKey      String?
  isPrivate      Boolean  @default(false)
  isPremium      Boolean  @default(false)
  stripeCustomerId String? @unique
  role           UserRole @default(USER)
  followersCount Int      @default(0)
  followingCount Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  birthdate      DateTime?
  lastSeenAt     DateTime?

  // Localização grosseira (geohash) para notificações por proximidade. A coluna
  // `location` geography é GERADA via SQL cru (ST_PointFromGeoHash), fora do
  // schema — igual a events.location. notifyRadiusKm é o raio de interesse.
  locationGeohash   String?
  locationUpdatedAt DateTime?
  notifyRadiusKm    Int       @default(10)

  // Ciclo de vida da conta. accountStatus é a fonte da verdade do estado;
  // os timestamps abaixo são marcadores. deactivatedAt = momento em que a conta
  // saiu de ACTIVE (vale tanto para desativação quanto para exclusão agendada).
  // scheduledDeletionAt só existe em PENDING_DELETION. anonymizedAt em ANONYMIZED.
  accountStatus         AccountStatus     @default(ACTIVE)
  deactivatedAt         DateTime?
  scheduledDeletionAt   DateTime?
  anonymizedAt          DateTime?
  events                Event[]
  attendances           EventAttendance[]
  posts                 Post[]
  comments              Comment[]
  reactions             Reaction[]
  commentReactions      CommentReaction[]
  eventInvitesSent      EventInvite[]     @relation("inviter")
  eventInvitesReceived  EventInvite[]     @relation("invited")
  socialAccounts        SocialAccount[]
  passwordResetCodes    PasswordResetCode[]

  // Relacionamentos para o sistema de follow
  following Follow[] @relation("follower")
  followers Follow[] @relation("following")

  reports Report[] @relation("reporterReports")
  reportsReceived Report[] @relation("targetUserReports")
  reviewedReports Report[] @relation("reportReviewer")

  featuredEventsCreated FeaturedEvent[] @relation("featuredEventCreator")
  subscriptions         Subscription[]

  categoryPreferences UserCategoryPreference[]

  // Chat
  conversationsCreated       Conversation[]            @relation("conversationsCreated")
  conversationParticipations ConversationParticipant[] @relation("conversationParticipations")
  messagesSent               Message[]                 @relation("messagesSent")
  blocksMade                 Block[]                   @relation("blocksMade")
  blocksReceived             Block[]                   @relation("blocksReceived")
  messageReactions           MessageReaction[]         @relation("messageReactions")

  // LGPD
  consent        UserConsent?
  consentLogs    ConsentAuditLog[]

  // Ciclo de vida da conta (motivo de saída / churn)
  accountLifecycleLogs AccountLifecycleLog[]

  // Notificações (push + in-app)
  deviceTokens  DeviceToken[]
  notifications Notification[]

  // Spots (rolês sugeridos, distintos de Event)
  spotsCreated        Spot[]                @relation("spotsCreated")
  spotGenerationUsage SpotGenerationUsage[]
  spotDiscoveryUsage  SpotDiscoveryUsage[]

  // Predicado do reconciler: PENDING_DELETION com scheduledDeletionAt vencido.
  @@index([accountStatus, scheduledDeletionAt])
  @@map("users")
}

// Código OTP de recuperação de senha. Guardamos o HASH do código (nunca em
// claro): um vazamento do banco não revela o código enviado por e-mail.
// `attempts` limita o brute-force no espaço de 6 dígitos; `usedAt` garante uso
// único. Só um código ativo por usuário (os anteriores são apagados no request).
model PasswordResetCode {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  // Busca o código vigente de um usuário (não usado e não expirado).
  @@index([userId, usedAt, expiresAt], map: "password_reset_codes_user_active_idx")
  @@map("password_reset_codes")
}

enum EventCategory {
  MUSIC
  SPORTS
  TECH
  GASTRONOMY
  ART
  EDUCATION
  NIGHTLIFE
  BUSINESS
  HEALTH_WELLNESS
  OUTDOORS
  GAMING
  FILM_THEATER
  FASHION
  RELIGION
  FAMILY
  PETS
  VOLUNTEERING
  PARTY
  OTHER
}

model UserCategoryPreference {
  id        String        @id @default(uuid())
  userId    String
  category  EventCategory
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
  @@map("user_category_preferences")
}

enum ConversationType {
  DIRECT
  GROUP
}

enum ParticipantRole {
  MEMBER
  ADMIN
}

model Conversation {
  id            String           @id @default(uuid())
  type          ConversationType
  title         String?
  createdById   String
  createdBy     User             @relation("conversationsCreated", fields: [createdById], references: [id])
  lastMessageAt DateTime?
  directKey     String?          @unique
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
  spot         Spot?

  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationParticipant {
  id              String          @id @default(uuid())
  conversationId  String
  conversation    Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId          String
  user            User            @relation("conversationParticipations", fields: [userId], references: [id], onDelete: Cascade)
  role            ParticipantRole @default(MEMBER)
  lastReadAt      DateTime?
  lastDeliveredAt DateTime?
  clearedAt       DateTime?
  joinedAt        DateTime        @default(now())
  leftAt          DateTime?
  createdAt       DateTime        @default(now())

  @@unique([conversationId, userId])
  @@index([userId, leftAt])
  @@index([conversationId, leftAt])
  @@map("conversation_participants")
}

enum MessageType {
  USER
  SYSTEM
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("messagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  type           MessageType  @default(USER)
  content        String?
  createdAt      DateTime     @default(now())
  editedAt       DateTime?
  deletedAt      DateTime?

  // Resposta/citação a outra mensagem da mesma conversa.
  replyToId String?
  replyTo   Message?  @relation("messageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("messageReplies")

  // Idempotência de envio: chave gerada pelo cliente (header Idempotency-Key).
  // Retry com a mesma chave devolve a mensagem existente em vez de duplicar.
  // Null = sem idempotência (Postgres trata nulls como distintos no unique).
  idempotencyKey String?

  attachments MessageAttachment[]
  reactions   MessageReaction[]
  reports     Report[]

  @@unique([conversationId, senderId, idempotencyKey])
  @@index([conversationId, createdAt])
  @@map("messages")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("messageReactions", fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}

enum AttachmentKind {
  IMAGE
  AUDIO
  VIDEO
}

model MessageAttachment {
  id        String         @id @default(uuid())
  messageId String
  message   Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  kind      AttachmentKind @default(IMAGE)
  url       String
  key       String
  format    String
  size      Int
  durationMs Int?
  waveform   Int[]
  width      Int?
  height     Int?
  thumbnailUrl String?
  order      Int            @default(0)
  createdAt  DateTime       @default(now())

  @@index([messageId, order])
  @@map("message_attachments")
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blocker   User     @relation("blocksMade", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("blocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

enum SocialProvider {
  GOOGLE
  FACEBOOK
}

model SocialAccount {
  id             String         @id @default(uuid())
  userId         String
  provider       SocialProvider
  providerUserId String
  email          String?
  createdAt      DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("social_accounts")
}

enum FollowStatus {
  PENDING
  ACCEPTED
}

model Follow {
  id          String       @id @default(uuid())
  follower    User         @relation("follower", fields: [followerId], references: [id])
  followerId  String
  following   User         @relation("following", fields: [followingId], references: [id])
  followingId String
  status      FollowStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  @@unique([followerId, followingId])
  @@index([followingId, status, id])
  @@index([followerId, status, id])
  @@map("follows")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  latitude    Float
  longitude   Float
  address     String?
  categories  EventCategory[]
  isPublic    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  maxCapacity Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  canceledAt  DateTime?

  authorId    String
  author      User     @relation(fields: [authorId], references: [id])

  attendances EventAttendance[]
  posts       Post[]
  comments    Comment[]
  reactions   Reaction[]
  invites     EventInvite[]
  reports     Report[]
  images      EventImage[]
  features    FeaturedEvent[]
  analyticsMetrics EventAnalyticsMetric[]

  @@index([date])
  @@index([isPublic, date])
  @@index([isFeatured, date, id])
  @@index([categories], type: Gin)
  @@map("events")
}

enum EventAnalyticsMetricType {
  VIEW
  SHARE
}

model EventAnalyticsMetric {
  id         String                   @id @default(uuid())
  eventId    String
  type       EventAnalyticsMetricType
  occurredAt DateTime                 @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, type, occurredAt])
  @@map("event_analytics_metrics")
}

enum AttendanceType {
  INTERESTED
  CONFIRMED
  NOT_INTERESTED
}

model EventAttendance {
  id        String         @id @default(uuid())
  type      AttendanceType @default(CONFIRMED)
  userId    String
  eventId   String
  createdAt DateTime       @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId, createdAt])
  @@map("event_attendances")
}

model Post {
  id        String    @id @default(uuid())
  content   String
  authorId  String
  eventId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  comments  Comment[]
  reactions Reaction[]

  @@index([eventId, createdAt])
  @@map("posts")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  authorId  String
  eventId   String?
  postId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  event  Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  post   Post?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  reports Report[]
  reactions CommentReaction[]

  @@index([eventId, createdAt])
  @@index([postId, createdAt])
  @@map("comments")
}

model EventInvite {
  id          String   @id @default(uuid())
  eventId     String
  inviterId   String
  invitedId   String
  createdAt   DateTime @default(now())

  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  inviter User  @relation("inviter", fields: [inviterId], references: [id])
  invited User  @relation("invited", fields: [invitedId], references: [id])

  @@unique([eventId, invitedId])
  @@index([invitedId])
  @@map("event_invites")
}

model Reaction {
  id        String   @id @default(uuid())
  userId    String
  eventId   String?
  postId    String?
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  post  Post?  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId], map: "reactions_user_event_unique")
  @@unique([userId, postId], map: "reactions_user_post_unique")
  @@map("reactions")
}

model CommentReaction {
  id        String   @id @default(uuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId], map: "comment_reactions_user_comment_unique")
  @@index([commentId])
  @@map("comment_reactions")
}

enum ReportReason {
  HATE_SPEECH
  SPAM_OR_FRAUD
  HARASSMENT
  INAPPROPRIATE_CONTENT
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED_INVALID
  RESOLVED_REMOVED
}

model Report {
  id         String       @id @default(uuid())
  reason     ReportReason
  details    String?
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?
  resolutionNote String?

  reporterId String
  reporter   User   @relation("reporterReports", fields: [reporterId], references: [id], onDelete: Cascade)

  targetUserId String?
  targetUser   User?   @relation("targetUserReports", fields: [targetUserId], references: [id], onDelete: SetNull)

  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)

  messageId String?
  message   Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  reviewerId String?
  reviewer   User?   @relation("reportReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([reporterId, eventId, status], map: "reports_reporter_event_status_idx")
  @@index([reporterId, commentId, status], map: "reports_reporter_comment_status_idx")
  @@index([reporterId, messageId, status], map: "reports_reporter_message_status_idx")
  @@index([reporterId, targetUserId, status], map: "reports_reporter_target_user_status_idx")
  @@index([reviewerId], map: "reports_reviewer_idx")
  @@index([status, createdAt, id], map: "reports_status_created_at_id_idx")
  @@unique([reporterId, eventId, status], map: "reports_reporter_event_status_unique")
  @@unique([reporterId, commentId, status], map: "reports_reporter_comment_status_unique")
  @@unique([reporterId, messageId, status], map: "reports_reporter_message_status_unique")
  @@unique([reporterId, targetUserId, status], map: "reports_reporter_target_user_status_unique")
  @@map("reports")
}

model EventImage {
  id        String   @id @default(uuid())
  url       String
  key       String
  format    String
  size      Int
  order     Int      @default(0)
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([eventId, order])
  @@map("event_images")
}

model FeaturedEvent {
  id         String    @id @default(uuid())
  eventId    String
  event      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  startsAt   DateTime
  endsAt     DateTime
  createdBy  String
  creator    User      @relation("featuredEventCreator", fields: [createdBy], references: [id])
  createdAt  DateTime  @default(now())
  canceledAt DateTime?

  @@index([eventId, canceledAt, startsAt, endsAt])
  @@map("featured_events")
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String             @unique
  stripePriceId        String
  status               SubscriptionStatus
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  // Método de pagamento (id do PaymentMethod no Stripe). Null = sem cartão. Um
  // trial criado pelo PaymentSheet nasce sem cartão; só vira premium quando o
  // SetupIntent conclui e grava o método aqui. "Sticky": eventos posteriores
  // sem o campo não zeram (ver upsertSubscriptionTx).
  defaultPaymentMethodId String?
  startedAt            DateTime           @default(now())
  // Timestamp do último evento Stripe aplicado. Comparado com event.created
  // pra descartar eventos fora de ordem (Stripe não garante ordering).
  lastSyncedAt         DateTime           @default(now())
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // userId NÃO é @unique: user pode ter histórico (canceladas + nova ativa).
  // Query "ativa": WHERE userId AND status IN (TRIALING, ACTIVE, PAST_DUE).
  @@index([userId, status])
  @@index([status, currentPeriodEnd])
  @@map("subscriptions")
}

model WebhookEvent {
  id            String   @id @default(uuid())
  stripeEventId String   @unique
  type          String
  processedAt   DateTime @default(now())
  payload       Json

  @@map("webhook_events")
}

// ── LGPD ────────────────────────────────────────────────────

model UserConsent {
  id                 String    @id @default(uuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Essencial (sempre true, imutável)
  essentialAccepted  Boolean   @default(true)

  // Os 7 consentimentos granulares da Política de Privacidade v1.0
  locationPrecise    Boolean   @default(false)  // GPS em tempo real
  socialFeed         Boolean   @default(false)  // Feed personalizado por amigos
  socialVisibility   Boolean   @default(false)  // Visibilidade de atividades
  pushNotifications  Boolean   @default(false)  // Notificações push
  marketing          Boolean   @default(false)  // Comunicações de marketing
  analytics          Boolean   @default(false)  // Analytics e métricas de uso
  surveys            Boolean   @default(false)  // Participação em pesquisas

  consentVersion     String    @default("1.0")
  ipAddress          String?
  userAgent          String?
  collectedAt        DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  revokedAt          DateTime?

  // @@index([userId]) removido — userId @unique já cria índice implícito
  @@map("user_consents")
}

enum ConsentAction {
  GRANTED
  UPDATED
  REVOKED
  EXPORTED
}

model ConsentAuditLog {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  action         ConsentAction
  changedFields  Json     // { field: string, from: boolean|null, to: boolean }[]
  ipAddress      String?
  userAgent      String?
  consentVersion String

  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("consent_audit_logs")
}

enum AccountLifecycleAction {
  DEACTIVATED
  DELETION_SCHEDULED
  REACTIVATED
}

// Log append-only do ciclo de vida da conta. Guarda o "motivo de saída"
// (opcional) informado ao desativar/excluir — fonte de analytics de churn.
// Sobrevive à anonimização (o usuário não é deletado, só anonimizado).
model AccountLifecycleLog {
  id        String                 @id @default(uuid())
  userId    String
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  action    AccountLifecycleAction
  reason    String?

  createdAt DateTime               @default(now())

  @@index([userId])
  @@index([action, createdAt])
  @@map("account_lifecycle_logs")
}

// ── Notificações ────────────────────────────────────────────

enum NotificationType {
  EVENT_NEARBY
  SPOT_NEARBY
  SPOT_JOIN
  SPOT_RENEWAL
  FOLLOW_REQUEST
  FOLLOW_ACCEPTED
  NEW_FOLLOWER
  EVENT_INVITE
  EVENT_COMMENT
  POST_COMMENT
  EVENT_REACTION
  POST_REACTION
  COMMENT_REACTION
  EVENT_ATTENDANCE
}

// Token de push (Expo) de um device do usuário. invalidatedAt marca soft-disable
// (ex.: DeviceNotRegistered no envio) sem apagar — preserva auditoria e permite
// reativar se o app re-registrar o mesmo token. O envio em si é da entrega 5.
model DeviceToken {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token             String    @unique
  platform          String?
  invalidatedAt     DateTime?
  invalidatedReason String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  pushTickets PushTicket[]

  @@index([userId])
  @@map("device_tokens")
}

// Ticket de um push enviado ao Expo. O envio retorna só o ticket (recebido pelos
// servidores do Expo, NÃO pelo device); o receipt — buscado ~15min depois — diz
// se entregou. status=PENDING até o reconciler ler o receipt; DeviceNotRegistered
// no receipt invalida o DeviceToken.
model PushTicket {
  id            String      @id @default(uuid())
  deviceTokenId String
  deviceToken   DeviceToken @relation(fields: [deviceTokenId], references: [id], onDelete: Cascade)
  receiptId     String?
  status        String      @default("PENDING")
  error         String?
  createdAt     DateTime    @default(now())

  @@index([status, createdAt])
  @@map("push_tickets")
}

// Notificação in-app (central + base do push). `dedupeKey` torna o fan-out
// idempotente (retry/duplo gatilho não duplica): a app monta a chave a partir do
// tipo + alvos. Referências de alvo (actor/event/post/comment) são colunas soltas,
// sem FK — a notificação é histórica/efêmera (expurgo por retenção) e tolera alvo
// removido. Só userId (destinatário) é relação, com cascade.
model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  actorId   String?
  eventId   String?
  postId    String?
  commentId String?
  spotId    String?
  title     String
  body      String
  data      Json?
  dedupeKey String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@unique([userId, dedupeKey])
  @@index([userId, readAt, createdAt])
  // Cobre o keyset (userId, createdAt DESC, id DESC): o `id` no índice evita
  // heap scan no desempate de createdAt igual. Btree serve via scan reverso.
  @@index([userId, createdAt, id])
  @@map("notifications")
}

enum SpotVisibility {
  PUBLIC
  FRIENDS
}

// Spot = rolê sugerido, ancorado num estabelecimento real (placeId do Google
// Places), com janela de tempo (startsAt/endsAt) e um grupo de chat criado junto.
// Distinto de Event: mais leve, efêmero, e o "ser membro" É participar do chat
// (conversationId). FRIENDS = visível só para follow mútuo do criador.
// A coluna `location` geography é GERADA via SQL cru, fora do schema — igual a
// events.location (ver migration).
model Spot {
  id          String          @id @default(uuid())
  title       String
  description String?
  categories  EventCategory[]
  visibility  SpotVisibility  @default(PUBLIC)
  placeId     String
  latitude    Float
  longitude   Float
  startsAt    DateTime
  endsAt      DateTime
  canceledAt  DateTime?
  // Marcado quando o lembrete de renovação é enviado; zerado ao renovar
  // (re-arma o lembrete para a nova janela). NULL = ainda não lembrado.
  renewalNotifiedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  creatorId String
  creator   User   @relation("spotsCreated", fields: [creatorId], references: [id])

  conversationId String       @unique
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@index([creatorId])
  // Lembrete: spots ativos vencendo ainda não lembrados.
  @@index([renewalNotifiedAt, endsAt, canceledAt], map: "spots_renewal_reminder_idx")
  @@index([categories], type: Gin)
  @@map("spots")
}

// Quota diária de geração de sugestões de spot (botão "gerar"). Uma linha por
// (usuário, dia); `count` é consumido de forma atômica. Free = 5, premium = 25
// (o limite é regra de negócio no service, não no schema). A renovação de spot
// no lifecycle consome desta MESMA quota.
model SpotGenerationUsage {
  userId    String
  day       DateTime @db.Date
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, day])
  @@map("spot_generation_usage")
}

// Cap diário de notificações de DESCOBERTA (SPOT_NEARBY fora da preferência,
// alcance premium): limita quantas o usuário recebe por dia (anti-spam). Mesma
// forma do SpotGenerationUsage, consumido em lote de forma atômica.
model SpotDiscoveryUsage {
  userId    String
  day       DateTime @db.Date
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, day])
  @@map("spot_discovery_usage")
}
