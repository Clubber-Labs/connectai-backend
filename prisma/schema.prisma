// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  name           String
  lastname       String
  username       String   @unique
  email          String   @unique
  password       String
  phone          String   @unique
  bio            String?
  avatarUrl      String?
  avatarKey      String?
  isPrivate      Boolean  @default(false)
  followersCount Int      @default(0)
  followingCount Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  birthdate      DateTime
  events           Event[]
  attendances      EventAttendance[]
  posts            Post[]
  comments         Comment[]
  reactions        Reaction[]
  commentReactions CommentReaction[]
  eventInvitesSent EventInvite[]     @relation("inviter")
  eventInvitesReceived EventInvite[] @relation("invited")

  // Relacionamentos para o sistema de follow
  following Follow[] @relation("follower")
  followers Follow[] @relation("following")

  reports Report[] @relation("reporterReports")
  @@map("users")
}

enum FollowStatus {
  PENDING
  ACCEPTED
}

model Follow {
  id          String       @id @default(uuid())
  follower    User         @relation("follower", fields: [followerId], references: [id])
  followerId  String
  following   User         @relation("following", fields: [followingId], references: [id])
  followingId String
  status      FollowStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  @@unique([followerId, followingId])
  @@index([followingId, status, id])
  @@index([followerId, status, id])
  @@map("follows")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  endDate     DateTime?
  latitude    Float
  longitude   Float
  address     String?
  category    String
  isPublic    Boolean  @default(true)
  maxCapacity Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  canceledAt  DateTime?

  authorId    String
  author      User     @relation(fields: [authorId], references: [id])

  attendances EventAttendance[]
  posts       Post[]
  comments    Comment[]
  reactions   Reaction[]
  invites     EventInvite[]
  reports     Report[]
  images      EventImage[]

  @@index([date])
  @@index([isPublic, date])
  @@map("events")
}

enum AttendanceType {
  INTERESTED
  CONFIRMED
  NOT_INTERESTED
}

model EventAttendance {
  id        String         @id @default(uuid())
  type      AttendanceType @default(CONFIRMED)
  userId    String
  eventId   String
  createdAt DateTime       @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId, createdAt])
  @@map("event_attendances")
}

model Post {
  id        String   @id @default(uuid())
  content   String
  authorId  String
  eventId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  comments  Comment[]
  reactions Reaction[]

  @@index([eventId, createdAt])
  @@map("posts")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  authorId  String
  eventId   String?
  postId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  event  Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  post   Post?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  reports Report[]
  reactions CommentReaction[]

  @@index([eventId, createdAt])
  @@index([postId, createdAt])
  @@map("comments")
}

model EventInvite {
  id          String   @id @default(uuid())
  eventId     String
  inviterId   String
  invitedId   String
  createdAt   DateTime @default(now())

  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  inviter User  @relation("inviter", fields: [inviterId], references: [id])
  invited User  @relation("invited", fields: [invitedId], references: [id])

  @@unique([eventId, invitedId])
  @@index([invitedId])
  @@map("event_invites")
}

model Reaction {
  id        String   @id @default(uuid())
  userId    String
  eventId   String?
  postId    String?
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  post  Post?  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId], map: "reactions_user_event_unique")
  @@unique([userId, postId], map: "reactions_user_post_unique")
  @@map("reactions")
}

model CommentReaction {
  id        String   @id @default(uuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId], map: "comment_reactions_user_comment_unique")
  @@index([commentId])
  @@map("comment_reactions")
}

enum ReportReason {
  HATE_SPEECH
  SPAM_OR_FRAUD
  HARASSMENT
  INAPPROPRIATE_CONTENT
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED_INVALID
  RESOLVED_REMOVED
}

model Report {
  id         String       @id @default(uuid())
  reason     ReportReason
  details    String?
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?

  reporterId String
  reporter   User   @relation("reporterReports", fields: [reporterId], references: [id], onDelete: Cascade)

  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)

  @@index([reporterId, eventId, status], map: "reports_reporter_event_status_idx")
  @@index([reporterId, commentId, status], map: "reports_reporter_comment_status_idx")
  @@unique([reporterId, eventId, status], map: "reports_reporter_event_status_unique")
  @@unique([reporterId, commentId, status], map: "reports_reporter_comment_status_unique")
  
  @@map("reports")
}

model EventImage {
  id        String   @id @default(uuid())
  url       String
  key       String
  format    String
  size      Int
  order     Int      @default(0)
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([eventId, order])
  @@map("event_images")
}
