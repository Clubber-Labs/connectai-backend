// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  name           String
  lastname       String
  username       String   @unique
  email          String   @unique
  password       String?
  phone          String?  @unique
  bio            String?
  avatarUrl      String?
  avatarKey      String?
  isPrivate      Boolean  @default(false)
  isPremium      Boolean  @default(false)
  followersCount Int      @default(0)
  followingCount Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  birthdate      DateTime?
  events           Event[]
  attendances      EventAttendance[]
  posts            Post[]
  comments         Comment[]
  reactions        Reaction[]
  commentReactions CommentReaction[]
  eventInvitesSent EventInvite[]     @relation("inviter")
  eventInvitesReceived EventInvite[] @relation("invited")
  socialAccounts   SocialAccount[]

  // Relacionamentos para o sistema de follow
  following Follow[] @relation("follower")
  followers Follow[] @relation("following")

  reports Report[] @relation("reporterReports")

  featuredEventsCreated FeaturedEvent[] @relation("featuredEventCreator")

  categoryPreferences UserCategoryPreference[]

  // Chat
  conversationsCreated       Conversation[]            @relation("conversationsCreated")
  conversationParticipations ConversationParticipant[] @relation("conversationParticipations")
  messagesSent               Message[]                 @relation("messagesSent")
  blocksMade                 Block[]                   @relation("blocksMade")
  blocksReceived             Block[]                   @relation("blocksReceived")
  @@map("users")
}

enum EventCategory {
  MUSIC
  SPORTS
  TECH
  GASTRONOMY
  ART
  EDUCATION
  NIGHTLIFE
  BUSINESS
  HEALTH_WELLNESS
  OUTDOORS
  GAMING
  FILM_THEATER
  FASHION
  RELIGION
  FAMILY
  PETS
  VOLUNTEERING
  PARTY
  OTHER
}

model UserCategoryPreference {
  id        String        @id @default(uuid())
  userId    String
  category  EventCategory
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
  @@map("user_category_preferences")
}

enum ConversationType {
  DIRECT
  GROUP
}

enum ParticipantRole {
  MEMBER
  ADMIN
}

model Conversation {
  id            String           @id @default(uuid())
  type          ConversationType
  title         String?
  createdById   String
  createdBy     User             @relation("conversationsCreated", fields: [createdById], references: [id])
  lastMessageAt DateTime?
  // Chave determinística do par DIRECT (uuids ordenados e juntados). null em GROUP.
  directKey     String?          @unique
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             String          @id @default(uuid())
  conversationId String
  conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User            @relation("conversationParticipations", fields: [userId], references: [id], onDelete: Cascade)
  role           ParticipantRole @default(MEMBER)
  lastReadAt     DateTime?
  joinedAt       DateTime        @default(now())
  leftAt         DateTime?
  createdAt      DateTime        @default(now())

  @@unique([conversationId, userId])
  @@index([userId, leftAt])
  @@index([conversationId, leftAt])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("messagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  content        String?
  createdAt      DateTime     @default(now())
  deletedAt      DateTime?

  attachments MessageAttachment[]
  reports     Report[]

  @@index([conversationId, createdAt])
  @@map("messages")
}

model MessageAttachment {
  id        String   @id @default(uuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url       String
  key       String
  format    String
  size      Int
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([messageId, order])
  @@map("message_attachments")
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blocker   User     @relation("blocksMade", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("blocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

enum SocialProvider {
  GOOGLE
  FACEBOOK
}

model SocialAccount {
  id             String         @id @default(uuid())
  userId         String
  provider       SocialProvider
  providerUserId String
  email          String?
  createdAt      DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("social_accounts")
}

enum FollowStatus {
  PENDING
  ACCEPTED
}

model Follow {
  id          String       @id @default(uuid())
  follower    User         @relation("follower", fields: [followerId], references: [id])
  followerId  String
  following   User         @relation("following", fields: [followingId], references: [id])
  followingId String
  status      FollowStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  @@unique([followerId, followingId])
  @@index([followingId, status, id])
  @@index([followerId, status, id])
  @@map("follows")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  endDate     DateTime?
  latitude    Float
  longitude   Float
  address     String?
  category    EventCategory
  isPublic    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  maxCapacity Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  canceledAt  DateTime?

  authorId    String
  author      User     @relation(fields: [authorId], references: [id])

  attendances EventAttendance[]
  posts       Post[]
  comments    Comment[]
  reactions   Reaction[]
  invites     EventInvite[]
  reports     Report[]
  images      EventImage[]
  features    FeaturedEvent[]

  @@index([date])
  @@index([isPublic, date])
  @@index([isFeatured, date, id])
  @@map("events")
}

enum AttendanceType {
  INTERESTED
  CONFIRMED
  NOT_INTERESTED
}

model EventAttendance {
  id        String         @id @default(uuid())
  type      AttendanceType @default(CONFIRMED)
  userId    String
  eventId   String
  createdAt DateTime       @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId, createdAt])
  @@map("event_attendances")
}

model Post {
  id        String   @id @default(uuid())
  content   String
  authorId  String
  eventId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  comments  Comment[]
  reactions Reaction[]

  @@index([eventId, createdAt])
  @@map("posts")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  authorId  String
  eventId   String?
  postId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  event  Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  post   Post?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  reports Report[]
  reactions CommentReaction[]

  @@index([eventId, createdAt])
  @@index([postId, createdAt])
  @@map("comments")
}

model EventInvite {
  id          String   @id @default(uuid())
  eventId     String
  inviterId   String
  invitedId   String
  createdAt   DateTime @default(now())

  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  inviter User  @relation("inviter", fields: [inviterId], references: [id])
  invited User  @relation("invited", fields: [invitedId], references: [id])

  @@unique([eventId, invitedId])
  @@index([invitedId])
  @@map("event_invites")
}

model Reaction {
  id        String   @id @default(uuid())
  userId    String
  eventId   String?
  postId    String?
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  post  Post?  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId], map: "reactions_user_event_unique")
  @@unique([userId, postId], map: "reactions_user_post_unique")
  @@map("reactions")
}

model CommentReaction {
  id        String   @id @default(uuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId], map: "comment_reactions_user_comment_unique")
  @@index([commentId])
  @@map("comment_reactions")
}

enum ReportReason {
  HATE_SPEECH
  SPAM_OR_FRAUD
  HARASSMENT
  INAPPROPRIATE_CONTENT
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED_INVALID
  RESOLVED_REMOVED
}

model Report {
  id         String       @id @default(uuid())
  reason     ReportReason
  details    String?
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?

  reporterId String
  reporter   User   @relation("reporterReports", fields: [reporterId], references: [id], onDelete: Cascade)

  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)

  messageId String?
  message   Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([reporterId, eventId, status], map: "reports_reporter_event_status_idx")
  @@index([reporterId, commentId, status], map: "reports_reporter_comment_status_idx")
  @@index([reporterId, messageId, status], map: "reports_reporter_message_status_idx")
  @@unique([reporterId, eventId, status], map: "reports_reporter_event_status_unique")
  @@unique([reporterId, commentId, status], map: "reports_reporter_comment_status_unique")
  @@unique([reporterId, messageId, status], map: "reports_reporter_message_status_unique")

  @@map("reports")
}

model EventImage {
  id        String   @id @default(uuid())
  url       String
  key       String
  format    String
  size      Int
  order     Int      @default(0)
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([eventId, order])
  @@map("event_images")
}

model FeaturedEvent {
  id         String    @id @default(uuid())
  eventId    String
  event      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  startsAt   DateTime
  endsAt     DateTime
  createdBy  String
  creator    User      @relation("featuredEventCreator", fields: [createdBy], references: [id])
  createdAt  DateTime  @default(now())
  canceledAt DateTime?

  @@index([eventId, canceledAt, startsAt, endsAt])
  @@map("featured_events")
}
